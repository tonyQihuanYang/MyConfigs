{
  "vim.leader": "<space>",
  "vim.useSystemClipboard": true,
  "vim.hlsearch": true,
  "vim.incsearch": true,
  
  "vim.normalModeKeyBindingsNonRecursive": [
    // Clear search highlight
    { "before": ["<CR>"], "commands": [":nohl"] },
    
    // Tab management
    { "before": ["t", "h"], "commands": ["workbench.action.firstEditorInGroup"] },
    { "before": ["t", "k"], "commands": ["workbench.action.nextEditor"] },
    { "before": ["t", "j"], "commands": ["workbench.action.previousEditor"] },
    { "before": ["t", "l"], "commands": ["workbench.action.lastEditorInGroup"] },
    { "before": ["t", "t"], "commands": ["workbench.action.files.newUntitledFile"] },
    { "before": ["t", "d"], "commands": ["workbench.action.closeActiveEditor"] },
    
    // Navigation - matching IntelliJ
    { "before": ["[", "["], "commands": ["editor.action.marker.prev"] },
    { "before": ["]", "]"], "commands": ["editor.action.marker.next"] },
    { "before": ["<C-a>"], "commands": ["workbench.action.showCommands"] },
    { "before": ["g", "u"], "commands": ["references-view.findReferences"] },
    { "before": ["g", "i"], "commands": ["editor.action.goToImplementation"] },
    { "before": ["g", "d"], "commands": ["editor.action.revealDefinition"] },
    { "before": ["g", "t"], "commands": ["testing.goToTest"] },
    { "before": ["g", "b"], "commands": ["workbench.action.navigateBack"] },
    { "before": ["g", "f"], "commands": ["workbench.action.navigateForward"] },
    
    // Leader key mappings - File/Search
    { "before": ["<leader>", "f", "f"], "commands": ["workbench.action.quickOpen"] },
    { "before": ["<leader>", "f", "w"], "commands": ["workbench.action.findInFiles"] },
    { "before": ["<leader>", "f", "p"], "commands": ["workbench.action.quickOpen"] },
    { "before": ["<leader>", "f", "n"], "commands": ["revealFileInOS"] },
    { "before": ["<leader>", "f", "b"], "commands": ["workbench.action.showAllEditors"] },
    { "before": ["<leader>", "s", "p"], "commands": ["workbench.action.quickOpen"] },
    { "before": ["<leader>", "s", "g"], "commands": ["workbench.action.findInFiles"] },
    { "before": ["<leader>", "s", "r"], "commands": ["references-view.findReferences"] },
    { "before": ["<leader>", "s", "s"], "commands": ["workbench.action.gotoSymbol"] },
    { "before": ["<leader>", "s", "x"], "commands": ["workbench.actions.view.problems"] },
    
    // File browser
    { "before": ["<leader>", "n"], "commands": ["workbench.view.explorer"] },
    { "before": ["<leader>", "b"], "commands": ["workbench.action.toggleSidebarVisibility"] },
    
    // LSP
    { "before": ["<leader>", "l", "p"], "commands": ["editor.action.formatDocument"] },
    
    // Debug
    { "before": ["<leader>", "d", "r"], "commands": ["workbench.action.debug.start"] },
    { "before": ["<leader>", "d", "d"], "commands": ["workbench.action.debug.run"] },
    { "before": ["<leader>", "d", "c"], "commands": ["workbench.action.debug.continue"] },
    { "before": ["<leader>", "d", "j"], "commands": ["workbench.action.debug.stepOver"] },
    { "before": ["<leader>", "d", "k"], "commands": ["workbench.action.debug.stepInto"] },
    { "before": ["<leader>", "d", "o"], "commands": ["workbench.action.debug.stepOut"] },
    { "before": ["<leader>", "d", "t"], "commands": ["workbench.action.debug.stop"] },
    { "before": ["<leader>", "d", "b", "b"], "commands": ["editor.debug.action.toggleBreakpoint"] },
    { "before": ["<leader>", "d", "b", "c"], "commands": ["editor.debug.action.conditionalBreakpoint"] },
    { "before": ["<leader>", "d", "s"], "commands": ["workbench.action.debug.stepOut"] },
    { "before": ["<leader>", "d", "q"], "commands": ["workbench.action.closePanel"] },
    
    // Errors/Diagnostics
    { "before": ["<leader>", "x", "x"], "commands": ["workbench.actions.view.problems"] },
    { "before": ["<leader>", "x", "w"], "commands": ["workbench.actions.view.problems"] },
    { "before": ["<leader>", "x", "d"], "commands": ["workbench.actions.view.problems"] },
    
    // Symbols outline
    { "before": ["<leader>", "o"], "commands": ["outline.focus"] },
    
    // Terminal
    { "before": ["\\", "t"], "commands": ["workbench.action.terminal.toggleTerminal"] },
    
    // Reload config
    { "before": ["\\", "r"], "commands": ["workbench.action.reloadWindow"] }
  ],
  
  "vim.insertModeKeyBindings": [
    { "before": ["<C-Insert>"], "commands": ["workbench.action.files.newUntitledFile"] },
    { "before": ["<C-Delete>"], "commands": ["workbench.action.closeActiveEditor"] }
  ],
  
  "vim.visualModeKeyBindingsNonRecursive": [
    { "before": ["Q"], "commands": ["editor.action.formatSelection"] }
  ]
}
